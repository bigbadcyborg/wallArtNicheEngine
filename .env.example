# Copy to .env (or set as environment variables) and fill in what you have.
# Everything is optional: without keys the app runs in offline/dry-run mode.

# Database. Defaults to sqlite:///./wallart.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/wallart

# Anthropic API key for AI brief/listing generation (template fallback used if unset)
# ANTHROPIC_API_KEY=sk-ant-...

# Etsy Open API v3 (publisher stays in dry-run mode until all three are set)
# ETSY_API_KEY=...
# ETSY_SHOP_ID=...
# ETSY_ACCESS_TOKEN=...

# Where exported assets / bundles are written. Defaults to ./storage
# STORAGE_DIR=./storage
