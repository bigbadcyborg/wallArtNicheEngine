# Copy to .env (or set as environment variables) and fill in what you have.
# Everything is optional: without keys the app runs in offline/dry-run mode.

# Database. Defaults to sqlite:///./wallart.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/wallart

# Anthropic API key for AI brief/listing generation (template fallback used if unset)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key for image generation on the Generate tab
# (placeholder images are produced if unset). Model defaults to Nano Banana.
# GEMINI_API_KEY=...
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# IMAGE_PROVIDER=gemini  # gemini or comfyui

# ComfyUI image generation (used when IMAGE_PROVIDER=comfyui)
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_WORKFLOW_PATH=./config/comfyui-workflow.json
# COMFYUI_TIMEOUT_SECONDS=120
# COMFYUI_OUTPUT_NODE_ID=9
# COMFYUI_PROMPT_NODE_ID=6

# Etsy Open API v3 (publisher stays in dry-run mode until all three are set)
# ETSY_API_KEY=...
# ETSY_SHOP_ID=...
# ETSY_ACCESS_TOKEN=...

# Where exported assets / bundles are written. Defaults to ./storage
# STORAGE_DIR=./storage
